import hashlib
import statistics

# Parameter Curve256189
n = 28948022309329048855892746252171976963257918617752773869725216245594308445583
# Rahasia yang menjaga "Parasit" tetap melekat kuat
secret = hashlib.sha256(b"GAUNTLET-2026").digest()

def H(k_val):
    k_bytes = int(k_val).to_bytes(32, 'big')
    # Double-hash construction untuk memastikan tidak ada pola linear
    h = hashlib.sha512(secret + k_bytes).digest()
    return int.from_bytes(h, 'big') % n

def wrap(k):
    return (k + H(k)) % n

