def find_collision(max_attempts=100000):
    seen = {}
    for i in range(max_attempts):
        k_try = random.randint(1, n-1)
        kw_try = wrap(k_try, secret, n)

        if kw_try in seen:
            k_prev = seen[kw_try]
            if k_prev != k_try:
                print(f"    🎯 COLLISION DETECTED! k1={k_prev}, k2={k_try}")
                return True
        else:
            seen[kw_try] = k_try
    return False

