# -----------------------------------------------------------------------------
# FPOW Implementation
# -----------------------------------------------------------------------------
def H(secret, k, n):
    k_bytes = int(k).to_bytes(32, 'big')
    h1 = hashlib.sha512(secret + k_bytes).digest()
    h2 = hashlib.sha512(h1 + k_bytes).digest()
    return int.from_bytes(h1 + h2, 'big') % n

def wrap(k, secret, n):
    return (k + H(secret, k, n)) % n

